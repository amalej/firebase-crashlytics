{
  "name": "firebase-crashlytics",
  "version": "0.1.0",
  "description": "Delete crash reports from Firebase Crashlytics",
  "main": "lib/index.js",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/amalej/firebase-crashlytics"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "jest",
    "deploy": "npm run build && npm publish"
  },
  "files": [
    "lib"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./lib/index.d.mts",
        "default": "./lib/index.mjs"
      },
      "require": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      }
    },
    "./*": {
      "import": {
        "types": "./lib/*.d.mts",
        "default": "./lib/*.mjs"
      },
      "require": {
        "types": "./lib/*.d.ts",
        "default": "./lib/*.js"
      }
    }
  },
  "keywords": [
    "firebase",
    "crashlytics",
    "deleteCrashReports",
    "delete crash reports"
  ],
  "author": "amalej",
  "license": "ISC",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "google-auth-library": "^9.15.0"
  }
}
